{
  "name": "lit-critic",
  "displayName": "lit-critic",
  "description": "Multi-lens editorial review system for fiction manuscripts",
  "version": "2.20.1",
  "publisher": "alexisargyris",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexisargyris/lit-critic.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:CANON.md"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "literaryCritic.analyze",
        "title": "lit-critic: Analyze",
        "icon": "$(search)"
      },
      {
        "command": "literaryCritic.refreshKnowledge",
        "title": "lit-critic: Update Knowledge (AI)",
        "icon": "$(refresh)"
      },
      {
        "command": "literaryCritic.resetKnowledgeOverride",
        "title": "lit-critic: Reset Knowledge Override",
        "icon": "$(discard)"
      },
      {
        "command": "literaryCritic.deleteKnowledgeEntity",
        "title": "lit-critic: Delete Knowledge Entity",
        "icon": "$(trash)"
      },
      {
        "command": "literaryCritic.openKnowledgeReviewPanel",
        "title": "lit-critic: Open Knowledge Review Panel",
        "icon": "$(edit)"
      },
      {
        "command": "literaryCritic.nextKnowledgeEntity",
        "title": "lit-critic: Next Knowledge Entity"
      },
      {
        "command": "literaryCritic.previousKnowledgeEntity",
        "title": "lit-critic: Previous Knowledge Entity"
      },
      {
        "command": "literaryCritic.viewSession",
        "title": "lit-critic: View Session Details"
      },
      {
        "command": "literaryCritic.deleteSession",
        "title": "lit-critic: Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "literaryCritic.refreshLearning",
        "title": "lit-critic: Refresh Learning Data",
        "icon": "$(refresh)"
      },
      {
        "command": "literaryCritic.exportLearning",
        "title": "lit-critic: Export Learning to LEARNING.md",
        "icon": "$(export)"
      },
      {
        "command": "literaryCritic.resetLearning",
        "title": "lit-critic: Reset All Learning Data",
        "icon": "$(clear-all)"
      },
      {
        "command": "literaryCritic.deleteLearningEntry",
        "title": "lit-critic: Delete Learning Entry",
        "icon": "$(trash)"
      },
      {
        "command": "literaryCritic.acceptFinding",
        "title": "lit-critic: Accept Finding",
        "icon": "$(check)"
      },
      {
        "command": "literaryCritic.rejectFinding",
        "title": "lit-critic: Reject Finding",
        "icon": "$(close)"
      },
      {
        "command": "literaryCritic.discuss",
        "title": "lit-critic: Discuss Finding",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "literaryCritic.selectFinding",
        "title": "lit-critic: Select Finding"
      },
      {
        "command": "literaryCritic.reviewFinding",
        "title": "lit-critic: Review Current Finding"
      },
      {
        "command": "literaryCritic.selectModel",
        "title": "lit-critic: Config",
        "icon": "$(settings-gear)"
      },
      {
        "command": "literaryCritic.stopServer",
        "title": "lit-critic: Stop Server"
      },
      {
        "command": "literaryCritic.toggleEntityLock",
        "title": "lit-critic: Toggle Knowledge Lock",
        "icon": "$(lock)"
      },
      {
        "command": "literaryCritic.keepFlaggedEntity",
        "title": "lit-critic: Keep Flagged Entity",
        "icon": "$(check)"
      },
      {
        "command": "literaryCritic.deleteFlaggedEntity",
        "title": "lit-critic: Delete Flagged Entity",
        "icon": "$(trash)"
      },
      {
        "command": "literaryCritic.revealSessionInTree",
        "title": "lit-critic: Reveal Session in Tree"
      },
      {
        "command": "literaryCritic.renameScene",
        "title": "lit-critic: Rename Scene…",
        "icon": "$(edit)"
      },
      {
        "command": "literaryCritic.purgeOrphanedSceneRefs",
        "title": "lit-critic: Clean Up Stale Scene References",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "lit-critic",
      "properties": {
        "literaryCritic.repoPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the lit-critic installation directory (containing lit-critic-web.py). Required when opening a scene folder that is not inside the lit-critic repo."
        },
        "literaryCritic.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter"
        },
        "literaryCritic.serverPort": {
          "type": "number",
          "default": 8000,
          "description": "Port for the backend server"
        },
        "literaryCritic.analysisMode": {
          "type": "string",
          "default": "deep",
          "order": 41,
          "enum": [
            "quick",
            "deep"
          ],
          "enumDescriptions": [
            "Run deterministic code checks only",
            "Run full analysis with quick checker model slot",
            "Run full analysis with deep checker model slot"
          ],
          "description": "Analysis depth mode used for new sessions."
        },
        "literaryCritic.modelSlotFrontier": {
          "type": "string",
          "default": "",
          "order": 42,
          "description": "Model assigned to the frontier slot (critic tasks). Leave empty to use backend defaults."
        },
        "literaryCritic.modelSlotDeep": {
          "type": "string",
          "default": "",
          "order": 43,
          "description": "Model assigned to the deep checker slot. Leave empty to use backend defaults."
        },
        "literaryCritic.modelSlotQuick": {
          "type": "string",
          "default": "",
          "order": 44,
          "description": "Model assigned to the quick checker slot. Leave empty to use backend defaults."
        },
        "literaryCritic.sceneFolder": {
          "type": "string",
          "default": "text",
          "order": 47,
          "description": "Scene folder (relative to project root) used for scene discovery and refresh watchers."
        },
        "literaryCritic.sceneExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "txt"
          ],
          "order": 48,
          "description": "Scene file extensions (without dots) used for scene discovery and refresh watchers."
        },
        "literaryCritic.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the backend server on activation"
        },
        "literaryCritic.disableProblemDecorationColors": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, lit-critic sets workspace setting workbench.editor.decorations.colors=false to reduce diagnostic color tinting in file/tab labels. Affects all diagnostics in this workspace."
        },
        "literaryCritic.disableProblemDecorationBadges": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, lit-critic sets workspace setting workbench.editor.decorations.badges=false. Affects all diagnostics in this workspace."
        },
        "literaryCritic.knowledgeReviewPassTrigger": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "on_stale",
            "never"
          ],
          "enumDescriptions": [
            "Always run the reconciliation review pass after knowledge refresh.",
            "Only run when at least one scene was re-extracted.",
            "Never run the reconciliation review pass."
          ],
          "description": "Controls when the knowledge reconciliation review pass runs after a refresh."
        },
        "literaryCritic.autoUpdateOnSave": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "knowledge"
          ],
          "enumDescriptions": [
            "Manual only — no automatic AI work on save.",
            "Automatically update knowledge when changed scenes are detected on save."
          ],
          "description": "Controls automatic AI re-extraction when scene files are saved. 'off' = manual only; 'knowledge' = automatically update knowledge when changed scenes are detected on save."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lit-critic",
          "title": "lit-critic",
          "icon": "$(book)"
        },
        {
          "id": "lit-critic-review",
          "title": "lit-critic Review",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "lit-critic-review": [
        {
          "id": "literaryCritic.knowledgeReviewView",
          "name": "Knowledge Review",
          "type": "webview",
          "when": "literaryCritic.serverRunning"
        },
        {
          "id": "literaryCritic.discussionView",
          "name": "Findings Review",
          "type": "webview",
          "when": "literaryCritic.serverRunning"
        }
      ],
      "lit-critic": [
        {
          "id": "literaryCritic.scenes",
          "name": "Inputs"
        },
        {
          "id": "literaryCritic.indexes",
          "name": "Knowledge"
        },
        {
          "id": "literaryCritic.sessions",
          "name": "Sessions"
        },
        {
          "id": "literaryCritic.findings",
          "name": "Findings"
        },
        {
          "id": "literaryCritic.learning",
          "name": "Learning"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "literaryCritic.revealSessionInTree",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "literaryCritic.deleteLearningEntry",
          "when": "view == literaryCritic.learning && viewItem == learningEntry",
          "group": "inline"
        },
        {
          "command": "literaryCritic.resetKnowledgeOverride",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntityOverridden",
          "group": "inline"
        },
        {
          "command": "literaryCritic.deleteKnowledgeEntity",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntity",
          "group": "inline"
        },
        {
          "command": "literaryCritic.deleteKnowledgeEntity",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntityOverridden",
          "group": "inline"
        },
        {
          "command": "literaryCritic.toggleEntityLock",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntity",
          "group": "inline"
        },
        {
          "command": "literaryCritic.toggleEntityLock",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntityOverridden",
          "group": "inline"
        },
        {
          "command": "literaryCritic.toggleEntityLock",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntityLocked",
          "group": "inline"
        },
        {
          "command": "literaryCritic.keepFlaggedEntity",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntityFlagged",
          "group": "inline@1"
        },
        {
          "command": "literaryCritic.deleteFlaggedEntity",
          "when": "view == literaryCritic.indexes && viewItem == knowledgeEntityFlagged",
          "group": "inline@2"
        },
        {
          "command": "literaryCritic.renameScene",
          "when": "view == literaryCritic.scenes && viewItem == sceneProjection",
          "group": "1_modification@1"
        }
      ],
      "view/title": [
        {
          "command": "literaryCritic.refreshKnowledge",
          "when": "view == literaryCritic.indexes",
          "group": "navigation"
        },
        {
          "command": "literaryCritic.analyze",
          "when": "view == literaryCritic.sessions",
          "group": "navigation"
        },
        {
          "command": "literaryCritic.selectModel",
          "when": "view == literaryCritic.sessions",
          "group": "navigation"
        },
        {
          "command": "literaryCritic.deleteSession",
          "when": "view == literaryCritic.sessions",
          "group": "navigation"
        },
        {
          "command": "literaryCritic.refreshLearning",
          "when": "view == literaryCritic.learning",
          "group": "navigation"
        },
        {
          "command": "literaryCritic.exportLearning",
          "when": "view == literaryCritic.learning",
          "group": "navigation"
        },
        {
          "command": "literaryCritic.resetLearning",
          "when": "view == literaryCritic.learning"
        }
      ],
      "editor/title": [
        {
          "command": "literaryCritic.analyze",
          "when": "resourceExtname == .txt",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "literaryCritic.analyze",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "literaryCritic.nextFinding",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "editorTextFocus"
      }
    ],
    "colors": [
      {
        "id": "literaryCritic.authorOverrideForeground",
        "description": "Color for locked knowledge entries (tree view) and overridden fields (knowledge review panel).",
        "defaults": {
          "dark": "#C8A84B",
          "light": "#7A6000",
          "highContrast": "#FFCC00",
          "highContrastLight": "#7A6000"
        }
      },
      {
        "id": "literaryCritic.flaggedForReviewForeground",
        "description": "Color for knowledge entries flagged for review by the reconciliation pass.",
        "defaults": {
          "dark": "#E0943A",
          "light": "#B06B1A",
          "highContrast": "#FFA040",
          "highContrastLight": "#B06B1A"
        }
      },
      {
        "id": "literaryCritic.overriddenForeground",
        "description": "Color for knowledge entries that have author overrides applied.",
        "defaults": {
          "dark": "#5BAFAF",
          "light": "#2E7A7A",
          "highContrast": "#70D0D0",
          "highContrastLight": "#2E7A7A"
        }
      },
      {
        "id": "literaryCritic.staleForeground",
        "description": "Color for stale inputs, knowledge entries, and sessions in tree views.",
        "defaults": {
          "dark": "#CB6B6B",
          "light": "#A14040",
          "highContrast": "#FF6B6B",
          "highContrastLight": "#A14040"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package",
    "test": "mocha --exit --require ts-node/register \"../tests/vscode-extension/**/*.ts\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.33",
    "@types/proxyquire": "^1.3.31",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "mocha": "^10.2.0",
    "proxyquire": "^2.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
